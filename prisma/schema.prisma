// ===========================================================================
// Prisma Schema
//
// PostgreSQL datasource with Prisma Client generator.
// Implements the tenant, identity, membership, session, audit
// foundation (TASK-0005), auth provider persistence (TASK-0031),
// CRM customer domain, and conversation + message domain (R2).
//
// NOTE: Prisma 7+ requires datasource URL to be configured in
// prisma.config.ts, not in this schema file.
// ===========================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===========================================================================
// Enums
// ===========================================================================

enum UserStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum BusinessStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum MembershipStatus {
  INVITED
  ACTIVE
  DECLINED
  EXPIRED
  REMOVED
  LEFT
}

enum MembershipRole {
  OWNER
  ADMIN
  OPERATOR
  VIEWER
}

enum AuditActorType {
  USER
  SYSTEM
  AI_RECEPTIONIST
}

enum AuditResult {
  SUCCESS
  DENIED
  FAILED
}

enum CustomerStatus {
  ACTIVE
  ARCHIVED
}

enum ContactMethodType {
  EMAIL
  PHONE
  WHATSAPP
  INSTAGRAM
  TELEGRAM
  WEBSITE_CHAT
  CUSTOM
}

enum ConversationStatus {
  NEW
  OPEN
  ASSIGNED
  WAITING_CUSTOMER
  WAITING_OPERATOR
  ESCALATED
  RESOLVED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
  SYSTEM
  INTERNAL
}

enum MessageSenderType {
  CUSTOMER
  OPERATOR
  SYSTEM
  AI_RECEPTIONIST
}

enum ChannelType {
  INTERNAL
  WEBSITE_CHAT
}

enum AiClassificationStatus {
  NOT_REQUESTED
  PENDING
  READY
  FAILED
}

enum AiDraftStatus {
  NOT_REQUESTED
  PENDING
  READY
  APPROVED
  REJECTED
  FAILED
}

enum ReplyDraftSource {
  AI
  SYSTEM
  OPERATOR
}

enum ReplyDraftStatus {
  PENDING_REVIEW
  EDITED
  APPROVED
  DISCARDED
  SENT
}

// Per-business AI operating mode (PRD-v1.1 §5).
// MANUAL = Level 1 (default, AI generation disabled / fail closed).
// AI_ASSISTED = Level 2 (AI-assisted drafts; explicit per-business opt-in).
// Level 3 / Auto Pilot is future-only and intentionally NOT represented here.
enum BusinessAiMode {
  MANUAL
  AI_ASSISTED
}

// Knowledge Domain — verified business-context store (PRD-v1.1 §5.1, B-R2).
//
// Lifecycle/verification state of a business-context item. Only VERIFIED items
// are eligible to later back AI prompt context; DRAFT and ARCHIVED items must
// never be treated as usable AI context. This is the B-R2 provenance invariant.
enum BusinessContextItemStatus {
  DRAFT
  VERIFIED
  ARCHIVED
}

// Provenance of a business-context item's content. "Verified" provenance means
// business-approved/entered data (owner/operator approved, system-seeded, or
// imported business-owned data) — NOT model-prior knowledge, inference,
// scraped, or guessed data (§5.1).
enum BusinessContextItemSourceType {
  OWNER_APPROVED
  OPERATOR_APPROVED
  SYSTEM_SEEDED
  IMPORT
  OTHER
}

// AI Runtime — AI generation audit lifecycle status (PRD-v1.1 §5, B-R6).
//
// Records the lifecycle of a single AI generation ATTEMPT for traceability:
//   STARTED   = an attempt was opened (before/independent of any provider call).
//   SUCCEEDED = the attempt produced a result (metadata only — never content).
//   FAILED    = the attempt failed; a bounded, sanitized error is recorded.
enum AiGenerationStatus {
  STARTED
  SUCCEEDED
  FAILED
}

// ===========================================================================
// Models — Identity Domain
// ===========================================================================

model User {
  id            String     @id @default(uuid()) @db.Uuid
  email         String     @unique
  name          String
  locale        String     @default("en")
  status        UserStatus @default(ACTIVE)
  avatarUrl     String?    @map("avatar_url")
  emailVerified DateTime?  @map("email_verified")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  sessions              Session[]
  memberships           BusinessMembership[]
  createdBusinesses     Business[]           @relation("BusinessCreator")
  invitedMemberships    BusinessMembership[] @relation("MembershipInviter")
  auditEvents           AuditEvent[]         @relation("AuditActor")
  accounts              Account[]
  assignedConversations Conversation[]       @relation("ConversationAssignee")
  sentMessages          Message[]            @relation("MessageSender")

  @@map("users")
}

model Session {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("sessions")
}

// ===========================================================================
// Models — Tenancy Domain
// ===========================================================================

model Business {
  id              String         @id @default(uuid()) @db.Uuid
  name            String
  slug            String         @unique
  status          BusinessStatus @default(ACTIVE)
  aiMode          BusinessAiMode @default(MANUAL) @map("ai_mode")
  timezone        String         @default("Asia/Tehran")
  locale          String         @default("fa")
  createdByUserId String         @map("created_by_user_id") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  createdByUser          User                    @relation("BusinessCreator", fields: [createdByUserId], references: [id])
  memberships            BusinessMembership[]
  auditEvents            AuditEvent[]
  customers              Customer[]
  customerContactMethods CustomerContactMethod[]
  conversations          Conversation[]
  conversationMessages   Message[]
  replyDrafts            ReplyDraft[]
  businessContextItems   BusinessContextItem[]
  aiGenerationAuditLogs  AiGenerationAuditLog[]

  @@index([status])
  @@index([createdByUserId])
  @@map("businesses")
}

model BusinessMembership {
  id              String           @id @default(uuid()) @db.Uuid
  businessId      String           @map("business_id") @db.Uuid
  userId          String           @map("user_id") @db.Uuid
  role            MembershipRole   @default(VIEWER)
  status          MembershipStatus @default(INVITED)
  invitedByUserId String?          @map("invited_by_user_id") @db.Uuid
  joinedAt        DateTime?        @map("joined_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  business      Business @relation(fields: [businessId], references: [id])
  user          User     @relation(fields: [userId], references: [id])
  invitedByUser User?    @relation("MembershipInviter", fields: [invitedByUserId], references: [id])

  @@unique([userId, businessId])
  @@index([businessId])
  @@index([userId])
  @@index([businessId, role])
  @@index([businessId, status])
  @@map("business_memberships")
}

// ===========================================================================
// Models — Auth Provider Persistence (TASK-0031)
// ===========================================================================

model Account {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String   @map("provider_account_id")
  refreshToken      String?  @map("refresh_token") @db.Text
  accessToken       String?  @map("access_token") @db.Text
  expiresAt         Int?     @map("expires_at")
  tokenType         String?  @map("token_type")
  scope             String?
  idToken           String?  @map("id_token") @db.Text
  sessionState      String?  @map("session_state")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@index([expires])
  @@map("verification_tokens")
}

// ===========================================================================
// Models — Audit Domain
// ===========================================================================

model AuditEvent {
  id          String         @id @default(uuid()) @db.Uuid
  businessId  String?        @map("business_id") @db.Uuid
  actorType   AuditActorType @map("actor_type")
  actorUserId String?        @map("actor_user_id") @db.Uuid
  action      String
  targetType  String?        @map("target_type")
  targetId    String?        @map("target_id")
  result      AuditResult
  metadata    Json?
  createdAt   DateTime       @default(now()) @map("created_at")

  business  Business? @relation(fields: [businessId], references: [id])
  actorUser User?     @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([businessId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action])
  @@index([targetType, targetId])
  @@index([result])
  @@map("audit_events")
}

// ===========================================================================
// Models — CRM Domain
// ===========================================================================

model Customer {
  id          String         @id @default(uuid()) @db.Uuid
  businessId  String         @map("business_id") @db.Uuid
  displayName String         @map("display_name")
  status      CustomerStatus @default(ACTIVE)
  locale      String?
  notes       String?        @db.Text
  metadata    Json?
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  business       Business                @relation(fields: [businessId], references: [id])
  contactMethods CustomerContactMethod[]
  conversations  Conversation[]
  sentMessages   Message[]               @relation("MessageSenderCustomer")

  @@index([businessId, status])
  @@index([businessId, createdAt])
  @@index([businessId, displayName])
  @@map("customers")
}

model CustomerContactMethod {
  id         String            @id @default(uuid()) @db.Uuid
  customerId String            @map("customer_id") @db.Uuid
  businessId String            @map("business_id") @db.Uuid
  type       ContactMethodType
  value      String
  label      String?
  isPrimary  Boolean           @default(false) @map("is_primary")
  verified   Boolean           @default(false)
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id])

  @@unique([businessId, type, value])
  @@index([customerId])
  @@index([businessId, type])
  @@map("customer_contact_methods")
}

// ===========================================================================
// Models — Conversations Domain (R2)
// ===========================================================================

model Conversation {
  id                     String                 @id @default(uuid()) @db.Uuid
  businessId             String                 @map("business_id") @db.Uuid
  customerId             String?                @map("customer_id") @db.Uuid
  channel                ChannelType            @default(INTERNAL)
  status                 ConversationStatus     @default(NEW)
  subject                String?
  assignedUserId         String?                @map("assigned_user_id") @db.Uuid
  aiClassificationStatus AiClassificationStatus @default(NOT_REQUESTED) @map("ai_classification_status")
  aiDraftStatus          AiDraftStatus          @default(NOT_REQUESTED) @map("ai_draft_status")
  channelMetadata        Json?                  @map("channel_metadata")
  metadata               Json?
  closedAt               DateTime?              @map("closed_at")
  createdAt              DateTime               @default(now()) @map("created_at")
  updatedAt              DateTime               @updatedAt @map("updated_at")

  business     Business     @relation(fields: [businessId], references: [id])
  customer     Customer?    @relation(fields: [customerId], references: [id])
  assignedUser User?        @relation("ConversationAssignee", fields: [assignedUserId], references: [id])
  messages     Message[]
  replyDrafts  ReplyDraft[]

  @@unique([id, businessId])
  @@index([businessId, status])
  @@index([businessId, createdAt])
  @@index([businessId, assignedUserId])
  @@index([customerId])
  @@index([businessId, channel])
  @@map("conversations")
}

model Message {
  id               String            @id @default(uuid()) @db.Uuid
  conversationId   String            @map("conversation_id") @db.Uuid
  businessId       String            @map("business_id") @db.Uuid
  direction        MessageDirection
  senderType       MessageSenderType @map("sender_type")
  senderUserId     String?           @map("sender_user_id") @db.Uuid
  senderCustomerId String?           @map("sender_customer_id") @db.Uuid
  content          String            @db.Text
  contentType      String            @default("text/plain") @map("content_type")
  channelMetadata  Json?             @map("channel_metadata")
  metadata         Json?
  createdAt        DateTime          @default(now()) @map("created_at")

  conversation   Conversation @relation(fields: [conversationId, businessId], references: [id, businessId])
  business       Business     @relation(fields: [businessId], references: [id])
  senderUser     User?        @relation("MessageSender", fields: [senderUserId], references: [id])
  senderCustomer Customer?    @relation("MessageSenderCustomer", fields: [senderCustomerId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([businessId, createdAt])
  @@index([senderUserId])
  @@index([senderCustomerId])
  @@map("messages")
}

// ===========================================================================
// Models — Reply Drafts Domain
// ===========================================================================

model ReplyDraft {
  id                     String           @id @default(uuid()) @db.Uuid
  businessId             String           @map("business_id") @db.Uuid
  conversationId         String           @map("conversation_id") @db.Uuid
  sourceMessageId        String?          @map("source_message_id") @db.Uuid
  createdByUserId        String?          @map("created_by_user_id") @db.Uuid
  source                 ReplyDraftSource @default(SYSTEM)
  status                 ReplyDraftStatus @default(PENDING_REVIEW)
  draftText              String           @map("draft_text") @db.Text
  originalText           String?          @map("original_text") @db.Text
  reviewedByUserId       String?          @map("reviewed_by_user_id") @db.Uuid
  reviewedAt             DateTime?        @map("reviewed_at")
  sentMessageId          String?          @map("sent_message_id") @db.Uuid
  sentAt                 DateTime?        @map("sent_at")
  sentByUserId           String?          @map("sent_by_user_id") @db.Uuid
  modelProvider          String?          @map("model_provider")
  modelName              String?          @map("model_name")
  promptVersion          String?          @map("prompt_version")
  // AI generation metadata (B-R6). Populated only when source = AI. These are
  // METADATA ONLY — no raw prompt, no provider response content. They link a
  // draft to its generation audit record and capture the provenance fingerprint.
  aiGenerationAuditLogId String?          @map("ai_generation_audit_log_id") @db.Uuid
  aiContextHash          String?          @map("ai_context_hash")
  aiFinishReason         String?          @map("ai_finish_reason")
  aiGeneratedAt          DateTime?        @map("ai_generated_at")
  createdAt              DateTime         @default(now()) @map("created_at")
  updatedAt              DateTime         @updatedAt @map("updated_at")

  business     Business     @relation(fields: [businessId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@index([businessId, status])
  @@index([conversationId, status])
  @@index([businessId, createdAt])
  @@map("reply_drafts")
}

// ===========================================================================
// Models — Knowledge Domain (B-R2)
// ===========================================================================

// Tenant-scoped, verified business-context store with provenance (PRD-v1.1
// §5.1, B-R2). Holds business-approved facts (hours, address/location notes,
// service/menu facts, booking rules, delivery rules, FAQ answers, policies,
// and other business-owned knowledge).
//
// Each item carries a verification `status` and provenance (`sourceType` +
// source fields + verifier) so that ONLY VERIFIED, business-approved context
// may later be eligible for AI prompt usage. Unverified (DRAFT) or ARCHIVED
// items must never be treated as usable AI context.
//
// This model stores data only. It assembles no prompts (B-R5) and calls no AI
// provider (B-R4); it holds no customer / conversation / message content.
model BusinessContextItem {
  id               String                        @id @default(uuid()) @db.Uuid
  businessId       String                        @map("business_id") @db.Uuid
  category         String
  key              String
  value            String                        @db.Text
  status           BusinessContextItemStatus     @default(DRAFT)
  sourceType       BusinessContextItemSourceType @map("source_type")
  sourceLabel      String?                       @map("source_label")
  sourceUrl        String?                       @map("source_url")
  sourceMetadata   Json?                         @map("source_metadata")
  verifiedByUserId String?                       @map("verified_by_user_id") @db.Uuid
  verifiedAt       DateTime?                     @map("verified_at")
  createdByUserId  String?                       @map("created_by_user_id") @db.Uuid
  createdAt        DateTime                      @default(now()) @map("created_at")
  updatedAt        DateTime                      @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id])

  @@unique([id, businessId])
  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, category])
  @@map("business_context_items")
}

// ===========================================================================
// Models — AI Runtime (B-R6)
// ===========================================================================

// Tenant-scoped AI generation audit log (PRD-v1.1 §5, B-R6). Records ONE row per
// AI generation ATTEMPT so every generation is traceable: which business, which
// prompt version, which context fingerprint, which verified context item ids
// backed the prompt, which provider/model produced the result, the provider's
// request id / finish reason / token usage, the linked draft (if any), and
// whether the attempt started / succeeded / failed and when.
//
// PRIVACY INVARIANT (B-R6): this table stores METADATA ONLY. It deliberately has
// NO column for the raw prompt, the raw customer message, the conversation
// transcript, customer email/phone, the provider's raw response content, or raw
// source metadata. Only counts (promptCharCount / resultCharCount, token usage),
// stable identifiers, the deterministic non-content contextHash, item ids, and a
// bounded/sanitized error code+message may be stored. It performs no provider
// call, no send, and reads no customer / conversation / message content.
model AiGenerationAuditLog {
  id                     String             @id @default(uuid()) @db.Uuid
  businessId             String             @map("business_id") @db.Uuid
  // The conversation this generation was performed for, if known. A nullable,
  // FK-free trace id only — this table reads NO conversation row or message
  // content; it persists the id as audit metadata.
  conversationId         String?            @map("conversation_id") @db.Uuid
  // The draft this generation produced/updated, if any. A nullable, FK-free
  // reference (set at completion): a STARTED attempt or a FAILED attempt may
  // have no draft, so this stays loosely coupled and is never required.
  replyDraftId           String?            @map("reply_draft_id") @db.Uuid
  operation              String
  status                 AiGenerationStatus @default(STARTED)
  promptVersion          String?            @map("prompt_version")
  contextHash            String?            @map("context_hash")
  includedContextItemIds Json?              @map("included_context_item_ids")
  omittedContextItemIds  Json?              @map("omitted_context_item_ids")
  warnings               Json?
  providerId             String?            @map("provider_id")
  modelId                String?            @map("model_id")
  providerRequestId      String?            @map("provider_request_id")
  finishReason           String?            @map("finish_reason")
  promptTokens           Int?               @map("prompt_tokens")
  completionTokens       Int?               @map("completion_tokens")
  totalTokens            Int?               @map("total_tokens")
  promptCharCount        Int?               @map("prompt_char_count")
  resultCharCount        Int?               @map("result_char_count")
  errorCode              String?            @map("error_code")
  errorMessage           String?            @map("error_message")
  startedAt              DateTime           @default(now()) @map("started_at")
  completedAt            DateTime?          @map("completed_at")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")

  business Business @relation(fields: [businessId], references: [id])

  // Composite unique enables tenant-safe single-row writes (id + businessId),
  // consistent with the Area-A hardening pattern used elsewhere.
  @@unique([id, businessId])
  @@index([businessId, createdAt])
  @@index([businessId, status])
  @@index([businessId, conversationId])
  @@index([replyDraftId])
  @@map("ai_generation_audit_logs")
}
